# ─────────────────────────────────────────────────────────────
# JobPilot environment. Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# Database (Postgres)
DATABASE_URL=postgres://jobpilot:jobpilot@localhost:5432/jobpilot

# Redis (optional — queues degrade to synchronous if unset)
REDIS_URL=redis://localhost:6379

# Ports / origins
API_PORT=4000
WEB_PORT=3000
API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000

# Auth: signs session cookies. Generate: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-string-min-32-bytes

# Encryption for OAuth tokens at rest (AES-256-GCM). Must be 32 bytes base64.
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=replace-me-with-32-byte-base64-key

# AI provider: heuristic (default, no key) | anthropic | openai | ollama
# - anthropic: jobs are extracted + scored by Claude.
# - ollama: a LOCAL model on your machine (no API key, nothing leaves your box).
# All providers fall back to the deterministic engine on any error.
AI_PROVIDER=heuristic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (local AI). Set AI_PROVIDER=ollama to use it. Requires `ollama serve`
# running and the model pulled (e.g. `ollama pull llama3`).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Gmail OAuth (Phase 4). Least-privilege scope: gmail.readonly
# IMPORTANT: the redirect URI is the WEB origin (proxied to the API) so the
# session + CSRF cookies stay first-party through the Google round-trip. Add this
# EXACT value as an Authorized redirect URI on your Google OAuth client.
# See docs/GMAIL_SETUP.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback
